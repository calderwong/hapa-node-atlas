{
  "id": "hapa-turn-mining-protocol",
  "title": "Hapa Turn Mining Protocol",
  "created_at": "2026-05-26T00:00:00-07:00",
  "source_doc": "/Users/calderwong/Desktop/Hapa_Worldbuilding_Wiki/Operations/Flow Explainers/Hapa Turn Mining Protocol.md",
  "node": "hapa-second-brain",
  "purpose": "Convert exported AI conversations into a source-separated, chronological, queryable Hapa Turn and card layer.",
  "stages": [
    {
      "name": "Detect Exports",
      "inputs": ["ChatGPT conversations JSON", "NotebookLM chat HTML", "Gemini Takeout fragments"],
      "outputs": ["ai_chat_sources"]
    },
    {
      "name": "Normalize Threads",
      "inputs": ["source records"],
      "outputs": ["ai_chat_threads"]
    },
    {
      "name": "Preserve Messages",
      "inputs": ["platform-specific source rows"],
      "outputs": ["ai_chat_messages"]
    },
    {
      "name": "Pair Turns",
      "inputs": ["ordered user and model messages"],
      "outputs": ["ai_chat_turns with previous/next links"]
    },
    {
      "name": "Cardify",
      "inputs": ["turn objective, summary, taxonomy"],
      "outputs": ["hapa_turn_cards with image prompts"]
    },
    {
      "name": "Attribute",
      "inputs": ["turns and cards"],
      "outputs": ["information_attributions", "actor_memory_states", "information_derivations"]
    },
    {
      "name": "Search",
      "inputs": ["turns and cards"],
      "outputs": ["ai_turn_fts", "GET /api/turns", "GET /api/context chat_turns"]
    }
  ],
  "api": [
    "GET /api/turns",
    "GET /api/turns/profile",
    "GET /api/turns/{turn_id}",
    "GET /api/context"
  ],
  "cli": [
    "python3 hapa_second_brain/second_brain.py import-ai-chats",
    "python3 hapa_second_brain/second_brain.py turns --query \"Hapa protocol\"",
    "python3 hapa_second_brain/second_brain.py turn-profile"
  ],
  "tables": [
    "ai_chat_sources",
    "ai_chat_threads",
    "ai_chat_messages",
    "ai_chat_turns",
    "hapa_turn_cards",
    "ai_turn_fts"
  ],
  "attribution_rule": {
    "user_prompt": "Calder / CJ information_created",
    "model_response": "AI platform information_created and Calder / CJ information_consumed",
    "turn_card": "Hapa Second Brain plus Calder.agents() information_created"
  }
}
